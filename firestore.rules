rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      let userDoc = getUserData();
      return (userDoc != null && 'role' in userDoc.data) ? userDoc.data.role : null;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'ADMIN';
    }

    // --- USERS (public profile only) ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) || (
        isSignedIn() && request.resource.data.keys().hasAll(['average_rating', 'total_ratings'])
      );
      allow update: if request.auth.uid == 'w00Su74H23U8FWi2Slx4Y6fsP6m2' || isAdmin();
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'balance', 'reputation_score', 'current_tier', 'reputation_positive_streak', 'reputation_total_deducted', 'reputation_total_restored']) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['verification_status']) || (['PENDING', 'VERIFIED'].hasAny([request.resource.data.verification_status]) && resource.data.get('verification_status', '') != 'VERIFIED'))) || (
        isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['average_rating', 'total_ratings', 'updated_at', 'updatedAt'])
      );

      // Wishlist is owner-only
      match /wishlist_jobs/{jobId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
                              && request.resource.data.user_id == request.auth.uid
                              && request.resource.data.job_id == jobId;
        allow delete: if isOwner(userId);
      }
    }

    // --- USERS PRIVATE (PII/eKYC) ---
    match /users_private/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /verification_requests/{requestId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
                      && request.resource.data.user_id == request.auth.uid
                      && (request.resource.data.status == 'PENDING' || request.resource.data.status == 'APPROVED');
        allow update: if isAdmin();
        allow delete: if false;
      }
    }

    // Collection Group rule for Admin to fetch all requests
    match /{path=**}/verification_requests/{requestId} {
      allow read: if isAdmin();
    }

    // --- JOBS ---
    match /jobs/{jobId} {
      allow read: if true;

      function isValidJobCreate() {
        let d = request.resource.data;
        return d.employer_id == request.auth.uid
          && d.title is string && d.title.size() > 0 && d.title.size() <= 200
          && d.salary is number && d.salary > 0
          && d.salary_type in ['HOURLY', 'DAILY', 'JOB', 'PER_SHIFT', 'MONTHLY']
          && d.status in ['OPEN', 'ACTIVE', 'DRAFT', 'HIDDEN', 'FULL', 'CLOSED']
          && d.description is string;
      }

      // Cho phép EMPLOYER tạo job trực tiếp (bypass Cloud Function khi Spark plan)
      allow create: if isSignedIn() && isValidJobCreate();
      allow update: if isSignedIn() && (
        resource.data.employer_id == request.auth.uid ||
        resource.data.employerId == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shift_capacity', 'updated_at', 'updatedAt']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['view_count', 'updated_at', 'updatedAt'])
      );
      allow delete: if isSignedIn() && (
        resource.data.employer_id == request.auth.uid ||
        resource.data.employerId == request.auth.uid ||
        isAdmin()
      );


      match /shifts/{shiftId} {
        allow read: if true;
        // Dùng request.resource.data thay vì get() vì job chưa commit trong batch write
        allow create: if isSignedIn() && request.resource.data.employer_id == request.auth.uid;
        allow update, delete: if false;
      }
    }


    // --- APPLICATIONS ---
    match /applications/{applicationId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.candidate_id == request.auth.uid ||
        resource.data.candidateId == request.auth.uid ||
        resource.data.employer_id == request.auth.uid ||
        resource.data.employerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.candidate_id == request.auth.uid ||
        request.resource.data.candidateId == request.auth.uid
      ) && request.resource.data.status == 'NEW';
      allow update: if false;
      allow delete: if false;
      
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/applications/$(applicationId)).data.candidate_id == request.auth.uid ||
          get(/databases/$(database)/documents/applications/$(applicationId)).data.candidateId == request.auth.uid ||
          get(/databases/$(database)/documents/applications/$(applicationId)).data.employer_id == request.auth.uid ||
          get(/databases/$(database)/documents/applications/$(applicationId)).data.employerId == request.auth.uid ||
          isAdmin()
        );
        allow write: if false;
      }
    }

    // --- CONVERSATIONS / MESSAGES ---
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.candidate_id == request.auth.uid ||
        resource.data.employer_id == request.auth.uid ||
        resource.data.candidateId == request.auth.uid ||
        resource.data.employerId == request.auth.uid
      );
      
      // Cho phép tạo/cập nhật hội thoại từ Frontend khi bắt đầu chat
      allow create: if isSignedIn() && (
        request.resource.data.candidate_id == request.auth.uid ||
        request.resource.data.employer_id == request.auth.uid ||
        request.resource.data.candidateId == request.auth.uid ||
        request.resource.data.employerId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        resource == null ||
        resource.data.candidate_id == request.auth.uid ||
        resource.data.employer_id == request.auth.uid ||
        resource.data.candidateId == request.auth.uid ||
        resource.data.employerId == request.auth.uid
      );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.candidate_id == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.employer_id == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.candidateId == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.employerId == request.auth.uid
        );
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.candidate_id == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.employer_id == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.candidateId == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.employerId == request.auth.uid
        ) && request.resource.data.sender_id == request.auth.uid;
        
        allow update, delete: if false;
      }
    }

    // --- TRANSACTIONS ---
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid);
      allow create: if false;
      allow update, delete: if false;
    }

    // --- REVIEWS ---
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && request.resource.data.reviewer_id == request.auth.uid
                    && request.resource.data.rating >= 1 
                    && request.resource.data.rating <= 5;
      allow update, delete: if false;
    }

    // --- REPUTATION ---
    match /reputation_history/{entryId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /reputation_appeals/{appealId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    // --- CATEGORIES ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow delete: if false;
    }

    // --- FOLLOWS ---
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.follower_id == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.follower_id == request.auth.uid;
      allow update: if false;
    }

    // --- ANALYTICS ---
    match /analytics/{analyticId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- BOOST PACKAGES / PURCHASES ---
    match /packages/{packageId} {
      allow read: if true;
      allow write: if false;
    }

    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    // --- REPORTS ---
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- CCCD REGISTRY (For uniqueness checking) ---
    match /cccd_registry/{cccdNumber} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
