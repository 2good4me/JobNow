rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to get the current user's role from the users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /jobs/{jobId} {
      // Anyone authenticated can read jobs
      allow read: if request.auth != null;
      // Only EMPLOYER can create/update/delete, and they must be the owner (except maybe create where they set it)
      allow create: if request.auth != null && getUserRole() == 'EMPLOYER' && request.resource.data.employerId == request.auth.uid;
      allow update, delete: if request.auth != null && getUserRole() == 'EMPLOYER' && resource.data.employerId == request.auth.uid;
    }

    match /applications/{applicationId} {
      // CANDIDATE can read their own apps, EMPLOYER can read apps for their jobs
      allow read: if request.auth != null && (
        resource.data.candidateId == request.auth.uid || 
        (getUserRole() == 'EMPLOYER' && get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid)
      );
      // Only CANDIDATE can create
      allow create: if request.auth != null && getUserRole() == 'CANDIDATE' && request.resource.data.candidateId == request.auth.uid;
      // Only EMPLOYER who owns the job can update status
      allow update: if request.auth != null && getUserRole() == 'EMPLOYER' && get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid;
      // Applications usually shouldn't be deleted, or only by the candidate
      allow delete: if request.auth != null && resource.data.candidateId == request.auth.uid;
    }
  }
}